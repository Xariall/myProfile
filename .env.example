# Copy to .env and fill in values.
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase: Project Settings → Database → Connection string (URI), mode Session or Transaction.
# Example: postgres://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Leave unset to use SQLite (db.sqlite3) for local dev.
# DATABASE_URL=

# If DATABASE_URL omits sslmode, Django defaults POSTGRES_SSLMODE=require for PostgreSQL.
# POSTGRES_SSLMODE=require

# Cloudinary (optional — if unset, local MEDIA_ROOT ./media is used)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# SendGrid via django-anymail (optional — if unset, emails print to console in dev)
# SENDGRID_API_KEY=
# DEFAULT_FROM_EMAIL=you@verified-domain.com

# GitHub: репозитории на главной (раздел «Проекты»)
# GITHUB_USERNAME=your-login
# GITHUB_TOKEN=   # опционально: выше лимит API и доступ к приватным (если GITHUB_EXCLUDE_PRIVATE=False)
# GITHUB_REPOS_LIMIT=12
# GITHUB_CACHE_TTL=300
# GITHUB_EXCLUDE_FORKS=True
# GITHUB_EXCLUDE_PRIVATE=True
